  ["इज़राइल की संसद द्वारा 'स्पीकर ऑफ़ द नेसेट मेडल' प्राप्त करने वाले पहले व्यक्ति कौन बने?", "जो बाइडेन", "ऋषि सुनक", "नरेंद्र मोदी", "इमैनुएल मैक्रॉन", 2],
  ["रणजी ट्रॉफी 2025-26 जीतकर अपना पहला खिताब हासिल करने वाली जम्मू-कश्मीर ने फाइनल में किसे हराया?", "सौराष्ट्र", "मुंबई", "कर्नाटक", "विदर्भ", 2],
  ["सिक्किम के इकलौते 'पाक्योंग हवाई अड्डे' का नाम बदलकर किस स्वतंत्रता सेनानी के नाम पर रखा जाएगा?", "बी.बी. गुरुंग", "त्रिलोचन पोखरेल", "काजी लेंडुप दोरजी", "पवन कुमार चामलिंग", 1],
  ["कुनो नेशनल पार्क में हाल ही में 9 और चीते किस अफ्रीकी देश से लाए गए हैं?", "नामीबिया", "दक्षिण अफ्रीका", "बोत्सवाना", "तंजानिया", 2],
  ["भविष्य में कुछ चीतों को मध्य प्रदेश के किस वन्यजीव अभयारण्य में स्थानांतरित करने की योजना है?", "पेंच", "बांधवगढ़", "गांधी सागर वन्यजीव अभयारण्य", "कान्हा", 2],
  ["आंध्र प्रदेश में मानव-हाथी संघर्ष को कम करने के लिए कौन सा प्रोजेक्ट शुरू किया गया है?", "प्रोजेक्ट गजराज", "प्रोजेक्ट हनुमान", "प्रोजेक्ट हाथी", "प्रोजेक्ट वन रक्षक", 1],
  ["विश्व मोटापा एटलस 2026 के अनुसार, बच्चों में मोटापे के मामले में भारत विश्व में किस स्थान पर है?", "पहले", "दूसरे", "तीसरे", "पांचवें", 1],
  ["विश्व मोटापा दिवस प्रतिवर्ष किस तिथि को मनाया जाता है?", "4 फरवरी", "4 मार्च", "4 अप्रैल", "4 मई", 1],
  ["भारतीय संविधान का कौन सा अनुच्छेद राष्ट्रपति द्वारा राज्यपालों की नियुक्ति का प्रावधान करता है?", "अनुच्छेद 153", "अनुच्छेद 155", "अनुच्छेद 161", "अनुच्छेद 164", 1],
  ["भारत की 16वीं जनगणना (Census 2027) कितने चरणों में आयोजित की जाएगी?", "1", "2", "3", "4", 1],
  ["टाइम्स मैगज़ीन की 'वीमेन ऑफ़ द ईयर 2026' में शामिल सफीना हुसैन ने किस वर्ष रेमन मैग्सेसे पुरस्कार जीता था?", "2023", "2024", "2025", "2026", 2],
  ["केरल का 'अटुकल पोंगाला उत्सव' मुख्य रूप से देवी के किस रूप को समर्पित है?", "सरस्वती", "लक्ष्मी", "पार्वती", "दुर्गा", 2],
  ["1 ट्रिलियन डॉलर का मार्केट कैप हासिल करने वाली 'वॉलमार्ट इंक.' का मुख्यालय अमेरिका के किस राज्य में है?", "कैलिफोर्निया", "न्यूयॉर्क", "अर्कासस (Arkansas)", "टेक्सास", 2],
  ["79वीं संतोष ट्रॉफी 2025-26 के फाइनल में सेना ने केरल को हराया, यह मैच किस स्टेडियम में हुआ?", "इंदिरा गांधी स्टेडियम", "डाकुआखाना फुटबॉल स्टेडियम", "साल्ट लेक स्टेडियम", "जवाहरलाल नेहरू स्टेडियम", 1],
  ["थाईलैंड के प्रधान मंत्री के रूप में फिर से नियुक्त किए गए 'अनूतिन चार्नविराकुल' किस दल से संबंधित हैं?", "प्यू थाई", "मूव फॉरवर्ड", "भूमजैथई पार्टी", "पलांग प्रचारत", 2],
  ["राजस्थान भारत का सबसे बड़ा ऊन उत्पादक राज्य है, जो कुल उत्पादन का कितना प्रतिशत योगदान देता है?", "25%", "35%", "47%", "60%", 2],
  ["समग्र ऊन उत्पादन (wool production) में भारत का विश्व में कौन सा स्थान है?", "5वां", "7वां", "9वां", "12वां", 2]
];

// Convert compact format to object format
const quizData = rawData.map(item => ({
  q: item[0],
  options: [item[1], item[2], item[3], item[4]],
  ans: item[5]
}));

let currentQuiz = 0;
let score = 0;
let answered = false;
let timeLeft = 20; 
let timerInterval;
let userAnswers = [];

const questionEl = document.getElementById("question");
const optionsEl = document.getElementById("options");
const nextBtn = document.getElementById("nextBtn");
const quizDiv = document.getElementById("quiz");
const scoreBox = document.getElementById("scoreBox");
const finalScore = document.getElementById("finalScore");
const qCount = document.getElementById("q-count");
const scoreTracker = document.getElementById("score-tracker");
const timeEl = document.getElementById("time");
const progressBar = document.getElementById("progressBar");
const summaryBox = document.getElementById("summaryBox");

function startTimer() {
  timeLeft = 20;
  timeEl.innerText = timeLeft;
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    timeLeft--;
    timeEl.innerText = timeLeft;
    if(timeLeft <= 0) {
      clearInterval(timerInterval);
      handleTimeOut();
    }
  }, 1000);
}

function handleTimeOut() {
  if(answered) return;
  answered = true;
  const correctAns = quizData[currentQuiz].ans;
  const allBtns = optionsEl.querySelectorAll(".option");
  
  allBtns[correctAns].classList.add("correct");
  allBtns.forEach(b => { b.disabled = true; b.style.cursor = "default"; b.style.opacity = "0.7"; });
  
  userAnswers.push({
      q: quizData[currentQuiz].q,
      selected: "समय समाप्त ⏱",
      correct: quizData[currentQuiz].options[correctAns],
      isCorrect: false
  });

  nextBtn.style.display = "block";
  checkQuizEnd();
}

function loadQuiz() {
  answered = false;
  nextBtn.style.display = "none";
  const currentData = quizData[currentQuiz];
  
  const progressPercent = ((currentQuiz) / quizData.length) * 100;
  progressBar.style.width = progressPercent + "%";
  
  questionEl.innerText = currentData.q;
  qCount.innerText = "प्र " + (currentQuiz + 1) + " / " + quizData.length;
  scoreTracker.innerText = "⭐ " + score;
  optionsEl.innerHTML = "";
  
  currentData.options.forEach((opt, index) => {
    const btn = document.createElement("button");
    btn.innerText = opt;
    btn.classList.add("option");
    btn.onclick = () => selectOption(index, btn);
    optionsEl.appendChild(btn);
  });
  startTimer();
}

function selectOption(index, btn) {
  if(answered) return;
  answered = true;
  clearInterval(timerInterval); 
  
  const correctAns = quizData[currentQuiz].ans;
  const allBtns = optionsEl.querySelectorAll(".option");
  const isCorrect = index === correctAns;
  
  if(isCorrect) {
    btn.classList.add("correct");
    score++;
    scoreTracker.innerText = "⭐ " + score;
  } else {
    btn.classList.add("wrong");
    allBtns[correctAns].classList.add("correct");
  }

  userAnswers.push({
      q: quizData[currentQuiz].q,
      selected: quizData[currentQuiz].options[index],
      correct: quizData[currentQuiz].options[correctAns],
      isCorrect: isCorrect
  });
  
  allBtns.forEach(b => { b.disabled = true; b.style.cursor = "default"; });
  nextBtn.style.display = "block";
  checkQuizEnd();
}

function checkQuizEnd() {
    if(currentQuiz === quizData.length - 1) { nextBtn.innerText = "रिजल्ट देखें 🏆"; }
}

function nextQuestion() {
  currentQuiz++;
  if(currentQuiz < quizData.length) { loadQuiz(); } 
  else { showScore(); }
}

function showScore() {
  quizDiv.style.display = "none";
  scoreBox.style.display = "block";
  progressBar.style.width = "100%";
  finalScore.innerText = score + " / " + quizData.length;
  
  let summaryHTML = "<h3 style='text-align:center; margin-top:0; color:#1c1e21;'>उत्तरों की समीक्षा (Review)</h3>";
  userAnswers.forEach((ans, i) => {
      summaryHTML += `<div class="summary-item">
          <div class="s-q">Q${i+1}. ${ans.q}</div>
          ${ans.isCorrect
              ? `<div class="s-correct">✅ आपका उत्तर: ${ans.selected}</div>`
              : `<div class="s-wrong">❌ आपका उत्तर: ${ans.selected}</div>
                 <div class="s-true-ans">👉 सही उत्तर: ${ans.correct}</div>`
          }
      </div>`;
  });
  summaryBox.innerHTML = summaryHTML;

  confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 }, colors: ['#ea4335', '#fbbc04', '#34a853', '#1a73e8'] });
}

function retryQuiz() {
  currentQuiz = 0; score = 0; userAnswers = []; 
  quizDiv.style.display = "block"; scoreBox.style.display = "none";
  nextBtn.innerText = "अगला प्रश्न ➔";
  loadQuiz();
}

loadQuiz();
</script>
</body>
</html>
