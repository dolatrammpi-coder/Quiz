<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Current Affairs 2026 (Jan-Mar) - All Questions</title>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<style>
  body { 
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
    background-color: #f0f2f5; 
    margin: 0; 
    padding: 20px; 
    display: flex; 
    justify-content: center; 
  }
  .quiz-container { 
    background-color: white; 
    border-radius: 12px; 
    box-shadow: 0 8px 24px rgba(0,0,0,0.15); 
    padding: 25px; 
    max-width: 650px; 
    width: 100%; 
    position: relative;
    overflow: hidden;
  }
  .top-bar {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    border-bottom: 2px solid #f0f2f5;
    padding-bottom: 15px;
  }
  .back-btn {
    text-decoration: none;
    color: #ea4335;
    font-weight: bold;
    font-size: 1.1em;
    margin-right: 15px;
    padding: 8px 15px;
    background: #fce8e6;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .back-btn:hover { background: #fad2cf; }
  h1.quiz-title { margin: 0; color: #1c1e21; font-size: 1.4em; }

  h2 { color: #1c1e21; font-size: 1.15em; margin-top: 10px; line-height: 1.4;}
  
  .progress-container {
    width: 100%;
    background-color: #e4e6eb;
    border-radius: 5px;
    height: 8px;
    margin-bottom: 20px;
  }
  .progress-bar {
    height: 10px;
    background-color: #ea4335;
    border-radius: 5px;
    width: 0%;
    transition: width 0.4s ease;
  }

  .header-info { 
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    margin-bottom: 15px; 
    color: #606770; 
    font-size: 1em; 
    font-weight: bold;
  }
  
  .timer {
    background-color: #ffebe5;
    color: #d93025;
    padding: 5px 12px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .option { 
    background-color: #f0f2f5; 
    border: 2px solid transparent; 
    padding: 12px 15px; 
    width: 100%; 
    text-align: left; 
    margin-bottom: 8px; 
    border-radius: 8px; 
    cursor: pointer; 
    font-size: 1em; 
    font-weight: 500;
    transition: all 0.2s ease; 
    color: #1c1e21;
  }
  .option:hover:not(:disabled) { background-color: #e4e6eb; transform: translateY(-2px); }
  
  .correct { background-color: #e6f4ea; color: #137333; border: 2px solid #137333; animation: pop 0.3s ease; }
  .wrong { background-color: #fce8e6; color: #c5221f; border: 2px solid #c5221f; animation: shake 0.4s ease; }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25%, 75% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
  }
  @keyframes pop {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }

  .btn { 
    background-color: #1a73e8; 
    color: white; 
    border: none; 
    padding: 14px 20px; 
    border-radius: 8px; 
    cursor: pointer; 
    font-size: 1.1em; 
    font-weight: bold;
    display: none; 
    margin-top: 15px; 
    width: 100%;
    box-shadow: 0 4px 6px rgba(26, 115, 232, 0.3);
    transition: background-color 0.2s;
  }
  .btn:hover { background-color: #1557b0; }
  .score-box { text-align: center; display: none; padding: 20px 0;}
  #retryBtn { display: inline-block; background-color: #ea4335; margin-top: 15px; width: auto; padding: 12px 30px;}

  .summary-container {
    margin-top: 25px; text-align: left; max-height: 400px; overflow-y: auto; 
    padding: 15px; border: 1px solid #e4e6eb; border-radius: 8px; background: #fafafa;
  }
  .summary-item { margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #ddd; }
  .summary-item:last-child { border-bottom: none; }
  .s-q { font-weight: bold; color: #1c1e21; margin-bottom: 8px; font-size: 0.95em;}
  .s-correct { color: #137333; font-size: 0.95em; margin-bottom: 4px;}
  .s-wrong { color: #c5221f; font-size: 0.95em; margin-bottom: 4px;}
  .s-true-ans { color: #1a73e8; font-size: 0.95em; font-weight: bold; display: inline-block; padding: 3px 8px; background: #e8f0fe; border-radius: 4px;}
</style>
</head>
<body>
<div class="quiz-container">
  <div class="top-bar">
    <a href="current_affairs.html" class="back-btn">⬅️ वापस</a>
    <h1 class="quiz-title">📰 करेंट अफेयर्स (Jan-Mar 2026)</h1>
  </div>

  <div id="quiz">
    <div class="progress-container"><div class="progress-bar" id="progressBar"></div></div>
    <div class="header-info">
        <span id="q-count">प्र 1/181</span>
        <span class="timer">⏱ <span id="time">20</span>s</span>
        <span id="score-tracker">⭐ 0</span>
    </div>
    <h2 id="question">Loading...</h2>
    <div id="options"></div>
    <button id="nextBtn" class="btn" onclick="nextQuestion()">अगला प्रश्न ➔</button>
  </div>
  
  <div id="scoreBox" class="score-box">
    <h1 style="font-size: 3em; margin: 0;">🏆</h1>
    <h2>शानदार प्रदर्शन!</h2>
    <p id="finalScore" style="font-size: 2.5em; font-weight: bold; color: #1a73e8; margin: 10px 0;"></p>
    <div id="summaryBox" class="summary-container"></div>
    <button id="retryBtn" class="btn" onclick="retryQuiz()">फिर से अभ्यास करें 🔄</button>
  </div>
</div>

<script>
// Compact data format to handle all 181 questions efficiently
// Format: [Question, OptionA, OptionB, OptionC, OptionD, CorrectIndex]
const rawData = [
  ["महाराष्ट्र की पहली महिला DGP कौन थीं, जो 31 दिसंबर को सेवानिवृत्त हुईं?", "रश्मि शुक्ला", "सुमित्रा पवार", "गीता मित्तल", "नीलम गोरे", 0],
  ["'करुणा द पावर ऑफ कम्पैशन' के लेखक कैलाश सत्यार्थी को किस वर्ष नोबेल शांति पुरस्कार मिला था?", "2010", "2012", "2014", "2016", 2],
  ["वैश्विक आतंकवाद सूचकांक 2026 में 163 देशों की सूची में पाकिस्तान का स्थान क्या है?", "पहला", "दूसरा", "11वां", "13वां", 0],
  ["वैश्विक आतंकवाद सूचकांक (GTI) प्रतिवर्ष किस संस्था द्वारा प्रकाशित किया जाता है?", "विश्व बैंक", "इंस्टीट्यूट फॉर इकोनॉमिक्स एंड पीस", "संयुक्त राष्ट्र सुरक्षा परिषद", "एमनेस्टी इंटरनेशनल", 1],
  ["98वें अकादमी पुरस्कार (ऑस्कर) 2026 में सर्वश्रेष्ठ निर्देशक का पुरस्कार किसने जीता?", "पॉल थॉमस एंडरसन", "क्रिस्टोफर नोलन", "स्टीवन स्पीलबर्ग", "जेम्स कैमरून", 0],
  ["ऑस्कर 2026 में 'सिनर्स' फिल्म के लिए सर्वश्रेष्ठ अभिनेता का पुरस्कार किसे मिला?", "विल स्मिथ", "ओवेन कूपर", "माइकल बी. जॉर्डन", "किलियन मर्फी", 2],
  ["ऑस्कर 2026 में किस फिल्म ने सर्वाधिक छह (6) ऑस्कर पुरस्कार जीते?", "सिनर्स", "हैमनेट", "वन बैटल आफ्टर अनदर", "द सेज", 2],
  ["35वें सरस्वती सम्मान 2025 से सम्मानित होने वाले रामकुमार मुखोपाध्याय किस भाषा के लेखक हैं?", "हिंदी", "तमिल", "बंगाली", "ओडिया", 2],
  ["सरस्वती सम्मान किस फाउंडेशन द्वारा 1991 में स्थापित किया गया था?", "रिलायंस फाउंडेशन", "टाटा ट्रस्ट", "के.के. बिड़ला फाउंडेशन", "इन्फोसिस फाउंडेशन", 2],
  ["एबेल पुरस्कार 2026 विजेता गेर्ड फाल्टिंग्स का संबंध किस देश से है?", "नॉर्वे", "जर्मनी", "अमेरिका", "फ्रांस", 1],
  ["एबेल पुरस्कार (गणित का नोबेल) नॉर्वेजियन सरकार द्वारा किस वर्ष से प्रतिवर्ष प्रदान किया जा रहा है?", "1991", "1999", "2003", "2010", 2],
  ["राष्ट्रीय पिछड़ा वर्ग आयोग (NCBC) को किस वर्ष संवैधानिक दर्जा प्रदान किया गया था?", "1993", "2003", "2018", "2022", 2],
  ["भारतीय संविधान का कौन सा अनुच्छेद राष्ट्रीय पिछड़ा वर्ग आयोग से संबंधित है?", "अनुच्छेद 280", "अनुच्छेद 338B", "अनुच्छेद 155", "अनुच्छेद 94(c)", 1],
  ["BCCI नमन अवार्ड्स 2026 में सर्वश्रेष्ठ अंतर्राष्ट्रीय क्रिकेटर (महिला) का पुरस्कार किसने जीता?", "हरमनप्रीत कौर", "स्मृति मंधाना", "दीप्ति शर्मा", "शफाली वर्मा", 1],
  ["BCCI नमन अवार्ड्स 2026 में सी. के. नायडू लाइफटाइम अचीवमेंट पुरस्कार किसे मिला?", "राहुल द्रविड़ और रोजर बिन्नी", "सचिन तेंदुलकर और कपिल देव", "सुनील गावस्कर और रवि शास्त्री", "एम.एस. धोनी और वीरेंद्र सहवाग", 0],
  ["विश्व प्रसन्नता रिपोर्ट (World Happiness Report) किस संस्था द्वारा प्रकाशित की जाती है?", "विश्व आर्थिक मंच", "संयुक्त राष्ट्र सतत विकास समाधान नेटवर्क", "विश्व बैंक", "यूएनडीपी", 1],
  ["विश्व प्रसन्नता रिपोर्ट 2026 में दूसरे और तीसरे स्थान पर क्रमशः कौन से देश हैं?", "डेनमार्क और स्विट्जरलैंड", "आइसलैंड और डेनमार्क", "नॉर्वे और स्वीडन", "सिंगापुर और फिनलैंड", 1],
  ["भारत के 94वें शतरंज ग्रैंडमास्टर मयंक चक्रवर्ती किस राज्य से हैं?", "पश्चिम बंगाल", "असम", "तमिलनाडु", "महाराष्ट्र", 1],
  ["आंध्र प्रदेश के अमरावती में स्थापित 58 फुट ऊंची 'स्टैच्यू ऑफ सैक्रिफाइस' किस धातु की बनी है?", "लोहा", "तांबा", "कांस्य (Bronze)", "संगमरमर", 2],
  ["भाषाई आधार पर भारत के पहले राज्य के रूप में आंध्र प्रदेश का गठन किस वर्ष हुआ था?", "1947", "1950", "1953", "1956", 2],
  ["60वें ज्ञानपीठ पुरस्कार विजेता आर. वैरामुथु को किस वर्ष पद्म भूषण से सम्मानित किया गया था?", "2003", "2010", "2014", "2018", 2],
  ["सुभाष चंद्र बोस आपदा प्रबंधन पुरस्कार 2026 में संस्थागत श्रेणी का पुरस्कार किस राज्य के प्राधिकरण को मिला?", "ओडिशा", "गुजरात", "सिक्किम", "केरल", 2],
  ["सुभाष चंद्र बोस आपदा प्रबंधन पुरस्कार के तहत व्यक्तिगत श्रेणी में कितनी पुरस्कार राशि दी जाती है?", "₹1 लाख", "₹5 लाख", "₹10 लाख", "₹51 लाख", 1],
  ["ईरान का खार्ग द्वीप मुख्य रूप से किस व्यापार के लिए एक प्रमुख केंद्र है?", "मसाला", "यूरेनियम", "कच्चा तेल और एलपीजी", "सेमीकंडक्टर", 2],
  ["साहित्य अकादमी पुरस्कार कुल कितनी भाषाओं में दिया जाता है?", "22", "23", "24", "25", 2],
  ["प्रो रेसलिंग लीग 2026 के फाइनल में 'हरियाणा थंडर' ने किस टीम को हराया?", "पंजाब पैंथर्स", "यूपी वारियर्स", "दिल्ली दंगल वारियर्स", "मुंबई महारथी", 2],
  ["भारत और किर्गिस्तान के बीच संयुक्त सैन्य अभ्यास 'खंजर' पहली बार किस वर्ष शुरू किया गया था?", "2005", "2011", "2015", "2020", 1],
  ["जापान की लिबरल डेमोक्रेटिक पार्टी की नेता सनाए ताकाइची ने 465 सीटों में से कितनी सीटें जीतीं?", "250", "285", "316", "400", 2],
  ["पूर्व राज्यपाल विश्वभूषण हरिचंदन द्वारा लिखित पुस्तक 'बख्शी जगबंधुः द ग्रेट कमांडर' का विमोचन किस महीने में हुआ?", "जनवरी 2026", "फरवरी 2026", "मार्च 2026", "दिसंबर 2025", 1],
  ["राष्ट्रीय दलहन आत्मनिर्भरता मिशन के तहत भारत भर में कितनी नई दाल मिलें स्थापित करने का लक्ष्य है?", "100", "500", "1,000", "5,000", 2],
  ["राष्ट्रीय दलहन आत्मनिर्भरता मिशन की शुरुआत मध्य प्रदेश के किस जिले से की गई?", "भोपाल", "इंदौर", "सीहोर", "उज्जैन", 2],
  ["भ्रष्टाचार धारणा सूचकांक (CPI) 2024 में भारत का स्थान क्या था?", "85", "90", "96", "100", 2],
  ["भारत में उपभोक्ता मूल्य सूचकांक (CPI) की गणना के लिए नया आधार वर्ष क्या है?", "2011-12", "2021-22", "2022-23", "2023-24", 3],
  ["थोक मूल्य सूचकांक (WPI) की गणना के लिए नया आधार वर्ष क्या है?", "2011-12", "2021-22", "2022-23", "2023-24", 2],
  ["संथाली भाषा की लिपि 'ओल चिकी' का आविष्कार 1925 में किसने किया था?", "बिरसा मुंडा", "पंडित रघुनाथ मुर्मू", "सिद्धू कान्हू", "द्रौपदी मुर्मू", 1],
  ["ग्रेट निकोबार इंफ्रास्ट्रक्चर प्रोजेक्ट को किस ट्रिब्यूनल ने मंजूरी दी?", "सुप्रीम कोर्ट", "राष्ट्रीय हरित अधिकरण (NGT)", "पर्यावरण मंत्रालय", "नीति आयोग", 1],
  ["असम में ब्रह्मपुत्र नदी के नीचे बनने वाली भारत की पहली अंडरवाटर रोड-कम-रेल सुरंग की लंबाई कितनी होगी?", "14 किमी", "24 किमी", "34 किमी", "44 किमी", 2],
  ["बांग्लादेश की पहली महिला प्रधान मंत्री कौन थीं, जिनका हाल ही में 80 वर्ष की आयु में निधन हो गया?", "शेख हसीना", "बेगम खालिदा जिया", "डेलसी रोड्रिग्ज", "सनाए ताकाइची", 1],
  ["बेगम खालिदा जिया पहली बार बांग्लादेश की प्रधानमंत्री किस वर्ष बनी थीं?", "1985", "1991", "1996", "2001", 1],
  ["दुनिया की दूसरी सबसे बड़ी मीठे पानी की झील 'विक्टोरिया झील' से किस प्रमुख नदी का उद्गम होता है?", "कांगो", "नाइजर", "नील (Nile)", "ज़म्बेजी", 2],
  ["जलसंधि 'होर्मुज' फारस की खाड़ी को किस अन्य जल निकाय से जोड़ती है?", "अदन की खाड़ी", "ओमान की खाड़ी", "लाल सागर", "भूमध्य सागर", 1],
  ["शशि थरूर द्वारा लिखित 'द सेज हू रीइमेजिंड हिंदुइज्म' पुस्तक किस समाज सुधारक पर आधारित है?", "अय्यंकाली", "श्री नारायण गुरु", "चट्टम्पी स्वामीकल", "शंकराचार्य", 1],
  ["वाइब्रेंट विलेज प्रोग्राम (चरण II) की शुरुआत गृह मंत्री ने असम के किस जिले से की?", "धुबरी", "माजुली", "चाचा (Chacha)", "कोकराझार", 2],
  ["79वें बाफ्टा पुरस्कारों में भारतीय फिल्म 'बोंग' किस राज्य की पृष्ठभूमि पर आधारित है?", "असम", "मणिपुर", "पश्चिम बंगाल", "केरल", 1],
